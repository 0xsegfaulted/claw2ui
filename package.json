{
  "name": "claw2ui",
  "version": "2.2.0",
  "description": "Agent-to-UI bridge: serve interactive pages from IM agents via tunnel",
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./dsl": "./dist/dsl/index.js"
  },
  "typesVersions": {
    "*": {
      "dsl": ["dist/dsl/index.d.ts"]
    }
  },
  "bin": {
    "claw2ui": "./bin/claw2ui.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "node --test test/",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "bin/",
    "skill/",
    "start.sh",
    "stop.sh",
    "claw2ui.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agent",
    "ui",
    "tunnel",
    "im",
    "dashboard",
    "claw2ui",
    "a2ui",
    "cloudflare-tunnel",
    "visualization"
  ],
  "author": "0xsegfaulted",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xsegfaulted/claw2ui.git"
  },
  "homepage": "https://github.com/0xsegfaulted/claw2ui",
  "bugs": {
    "url": "https://github.com/0xsegfaulted/claw2ui/issues"
  },
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "marked": "^15.0.12",
    "nanoid": "^3.3.11",
    "sanitize-html": "^2.17.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "optionalDependencies": {
    "@huggingface/hub": "^2.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/sanitize-html": "^2.16.1"
  }
}
