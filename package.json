{
  "name": "clawboard",
  "version": "2.0.0",
  "description": "Agent-to-UI bridge: serve interactive pages from IM agents via tunnel",
  "main": "dist/server.js",
  "bin": {
    "clawboard": "./bin/clawboard.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "node --test test/",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "bin/",
    "skill/",
    "start.sh",
    "stop.sh",
    "clawboard.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agent",
    "ui",
    "tunnel",
    "im",
    "dashboard",
    "clawboard",
    "a2ui",
    "cloudflare-tunnel",
    "visualization"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xsegfaulted/clawboard.git"
  },
  "homepage": "https://github.com/0xsegfaulted/clawboard",
  "bugs": {
    "url": "https://github.com/0xsegfaulted/clawboard/issues"
  },
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "nanoid": "^3.3.11",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
